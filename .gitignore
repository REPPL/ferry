# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Cross-compiled ferry binaries ARE committed (install.sh selects one by uname).
# Keep this un-ignore so any future bin/ ignore rule cannot block them.
!bin/ferry-*

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/

# macOS
.DS_Store

# Local-only working material (notes, drafts, plans, issues log)
.work/

# Per-machine dependency overlays (never synced; layered by `apply --deps`)
deps/Brewfile.*.local

# Per-machine scope overrides (merged over ferry.toml at apply/capture time)
ferry.local.toml

# Per-machine dotfile/domain overlay (never synced; see docs/configuration.md)
local/
