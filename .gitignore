# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Cross-compiled ferry binaries are build artifacts (release-only since v0.4.0):
# `make build` regenerates them and the release workflow ships them as assets, so
# they are not committed and must never dirty the tree.
/bin/ferry-*

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/

# macOS
.DS_Store

# Per-machine dependency overlays (never synced; layered by `apply --deps`)
deps/Brewfile.*.local

# Per-machine scope overrides (merged over ferry.toml at apply/capture time)
ferry.local.toml

# Per-machine dotfile/domain overlay (never synced; see docs/reference/configuration.md)
local/

# stray bare dev build (release binaries are bin/ferry-<goos>-<arch>)
/bin/ferry

# Release checksum manifest: a build artifact shipped as a release asset,
# never committed (checksums leaving git history is the point of the design)
/bin/checksums.txt
