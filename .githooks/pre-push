#!/usr/bin/env bash
# Pre-push gate, run on every clone via the global ~/.githooks dispatcher
# (core.hooksPath): the CI check-job trio (build/vet/test) must pass natively
# before a push leaves this machine. The Linux behavioral-eval and security
# lanes stay in Actions (public repo, free runners).
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"
exec make preflight
